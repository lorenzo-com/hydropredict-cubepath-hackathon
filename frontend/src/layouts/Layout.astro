---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css"; // Estilos de tailwind
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="icon" type="image/png" sizes="32x32" href="/hydropredict-favicon.png">
		<ClientRouter />
	</head>
	<body>
		<slot />
	</body>
</html>
